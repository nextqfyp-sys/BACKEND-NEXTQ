# ============================================================
# Universal Learning Platform — Node.js Backend Environment
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/learning_platform

# Redis (required — used for rate limiting AND token whitelisting/blacklisting)
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars_change_me
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars_change_me
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3001

# Cloudinary (required — no local file system fallback)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Solana (Devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PRIVATE_KEY=your_base58_private_key
SOLANA_TOKEN_MINT_ADDRESS=2YQFHTscEGsNzCbyVDGDdhFDvtNGcaAvBVK97NWDCGBg
SOLANA_PROGRAM_ID=HHfqXJ9sZNNRJZGonfinA8gNY7vLpJ9tyrFQ4eAiQsgK

# HuggingFace AI Backend
HF_BASE_URL=https://ekrash1234-github-deploy-token.hf.space
HF_API_TOKEN=hf_your_token_here

# Rate Limits
RATE_LIMIT_QUIZZES_PER_DAY=20
RATE_LIMIT_PAPERS_PER_DAY=10
RATE_LIMIT_UPLOADS_PER_DAY=5
QUIZ_COOLDOWN_SECONDS=30
MAX_UPLOAD_SIZE_MB=10
